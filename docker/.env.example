# Docker Compose environment variables for crossmatch-service.
# Copy this file to .env and fill in actual values.
#
#   cp .env.example .env
#
# The .env file is gitignored and will not be committed.

# ----- Build -----
USERID=1000

# ----- Dev environment -----
MAKE_MIGRATIONS=false
DJANGO_DEBUG=true
LOG_LEVEL=DEBUG
DEV_MODE=true

# ----- Django superuser -----
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=password
DJANGO_SUPERUSER_EMAIL=test@example.com

# ----- Database -----
DATABASE_HOST=django-db
DATABASE_PORT=5432
DATABASE_DB=scimma_crossmatch_service
DATABASE_USER=crossmatch_service_admin
DATABASE_PASSWORD=password

# ----- Valkey / Redis -----
VALKEY_SERVICE=redis
VALKEY_PORT=6379

# ----- Application -----
APP_ROOT_DIR=/opt

# ----- ANTARES broker -----
ANTARES_API_KEY=
ANTARES_API_SECRET=
ANTARES_TOPIC=lsst_scimma_quality_transient
ANTARES_GROUP_ID=

# ----- Lasair broker -----
LASAIR_KAFKA_SERVER=lasair-lsst-kafka.lsst.ac.uk:9092
LASAIR_TOPIC=lasair_366SCiMMA_reliability_moderate
LASAIR_GROUP_ID=

# ----- Celery workers -----
CELERY_LOG_LEVEL=INFO
CELERY_CONCURRENCY=4
CELERY_WORKER_LIMIT_CPUS=4.0
CELERY_WORKER_LIMIT_MEMORY=4G

# ----- Crossmatch settings -----
CROSSMATCH_BATCH_MAX_WAIT_SECONDS=900
CROSSMATCH_BATCH_MAX_SIZE=100000
GAIA_HATS_URL=s3://stpubdata/gaia/gaia_dr3/public/hats
CROSSMATCH_RADIUS_ARCSEC=1.0

# ----- Flower -----
FLOWER_LOG_LEVEL=INFO
FLOWER_URL_PREFIX=
FLOWER_HOST=flower
FLOWER_PORT=8888
